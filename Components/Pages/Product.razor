@page "/product"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using System.ComponentModel.DataAnnotations

@inject ApplicationDbContext db

<h3 class="title">Products</h3>

<EditForm Model="newProduct" OnValidSubmit="AddProduct">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="form-card">

        <div class="form-group">
            <label>Product Name</label>
            <InputText @bind-Value="newProduct.Name" class="input" />
        </div>

        <div class="form-group">
            <label>Price</label>
            <InputNumber @bind-Value="newProduct.Price" class="input" />
        </div>

        <div class="form-group">
            <label>Category</label>
            <InputSelect @bind-Value="newProduct.CategoryId" class="input">
                <option value="">-- Select Category --</option>
                @foreach (var c in categories)
                {
                    <option value="@c.Id">@c.Name</option>
                }
            </InputSelect>
        </div>

        <button type="submit" class="btn">Add Product</button>

    </div>
</EditForm>

<hr />

<table class="table">
    <thead>
        <tr>
            <th>Name</th>
            <th>Price</th>
            <th>Category</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var p in products)
        {
            <tr>
                <td>@p.Name</td>
                <td>@p.Price.ToString("0.00")</td>
                <td>@p.CategoryName</td>
                <td>
                    <button class="btn-delete"
                            @onclick="() => DeleteProduct(p.Id)">
                        Delete
                    </button>
                </td>
            </tr>
        }
    </tbody>
</table>

@code {

    List<ProductRow> products = new();
    List<Category> categories = new();

    ProductCreateDto newProduct = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadCategories();
        await LoadProducts();
    }

    async Task LoadCategories()
    {
        categories = await db.Categories
            .OrderBy(c => c.Name)
            .ToListAsync();
    }

    async Task LoadProducts()
    {
        products = await db.Products
            .Include(p => p.Category)
            .OrderByDescending(x => x.Id)
            .Select(p => new ProductRow
            {
                Id = p.Id,
                Name = p.Name,
                Price = p.Price,
                CategoryName = p.Category != null ? p.Category.Name : "N/A"
            })
            .ToListAsync();
    }

    async Task AddProduct()
    {
        if (newProduct.CategoryId == 0)
        {
            // You can show validation here if needed
            return;
        }

        db.Products.Add(new global::Product
        {
            Name = newProduct.Name.Trim(),
            Price = newProduct.Price,
            CategoryId = newProduct.CategoryId
        });

        await db.SaveChangesAsync();

        newProduct = new ProductCreateDto();
        await LoadProducts();
    }

    async Task DeleteProduct(int id)
    {
        var p = await db.Products.FindAsync(id);
        if (p is null) return;

        db.Products.Remove(p);
        await db.SaveChangesAsync();
        await LoadProducts();
    }

    class ProductRow
    {
        public int Id { get; set; }
        public string Name { get; set; } = "";
        public decimal Price { get; set; }
        public string CategoryName { get; set; } = "";
    }

    class ProductCreateDto
    {
        [Required]
        [MinLength(2)]
        public string Name { get; set; } = "";

        [Range(0.01, 999999)]
        public decimal Price { get; set; }

        [Required]
        public int CategoryId { get; set; } = 0;
    }
}